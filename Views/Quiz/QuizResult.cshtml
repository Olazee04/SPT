@{
    ViewData["Title"] = "Quiz Result";
    int score = (int)(TempData["QuizResult_Score"] ?? 0);
    int total = (int)(TempData["QuizResult_Total"] ?? 0);
    int correct = (int)(TempData["QuizResult_Correct"] ?? 0);
    bool passed = score >= 70;
    string cssClass = passed ? "text-success" : "text-danger";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow border-0 leaderboard-card text-center">
                <div class="card-body py-5 px-4">

                    @if (passed)
                    {
                        <i class="fas fa-trophy fa-4x text-warning mb-3"></i>
                        @* FIX: font-weight-bold text-gray-800 → fw-bold *@
                        <h2 class="fw-bold">Congratulations!</h2>
                        <p class="text-muted">You passed this module. The next module is now unlocked!</p>
                    }
                    else
                    {
                        <i class="fas fa-times-circle fa-4x text-danger mb-3"></i>
                        <h2 class="fw-bold">Keep Trying!</h2>
                        <p class="text-muted">You need 70% to pass. Review the material and try again.</p>
                    }

                    <div class="display-3 fw-bold @cssClass my-3">@score%</div>

                    <div class="progress mx-auto mb-4" style="height:10px; max-width:200px; border-radius:8px;">
                        <div class="progress-bar @(passed ? "bg-success" : "bg-danger")" style="width:@score%"></div>
                    </div>

                    <div class="row g-2 mb-4 text-center">
                        <div class="col-4">
                            <div class="p-2 rounded border">
                                <div class="fw-bold fs-5 text-success">@correct</div>
                                <small class="text-muted">Correct</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded border">
                                <div class="fw-bold fs-5 text-danger">@(total - correct)</div>
                                <small class="text-muted">Wrong</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-2 rounded border">
                                <div class="fw-bold fs-5">@total</div>
                                <small class="text-muted">Total</small>
                            </div>
                        </div>
                    </div>

                    <p class="lead">You got <strong>@correct</strong> out of <strong>@total</strong> correct.</p>

                    <div class="d-grid gap-2 mt-4">
                        @if (passed)
                        {
                            <a asp-controller="Student" asp-action="Curriculum" class="btn btn-success btn-lg">
                                <i class="fas fa-arrow-right me-1"></i> Continue Learning
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Student" asp-action="Curriculum" class="btn btn-primary btn-lg">
                                <i class="fas fa-book-open me-1"></i> Back to Curriculum
                            </a>
                        }
                        <a asp-controller="Student" asp-action="Dashboard" class="btn btn-outline-secondary">
                            <i class="fas fa-home me-1"></i> Back to Dashboard
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
