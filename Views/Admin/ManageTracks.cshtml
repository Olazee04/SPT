@model List<SPT.Models.Track>
@{
    ViewData["Title"] = "Manage Tracks";
}

<div class="container-fluid p-4">

    <!-- HEADER-->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="fas fa-road me-2 text-primary"></i> Manage Tracks</h4>
            <small class="text-muted">Add, rename, or deactivate programmes (tracks) on the platform.</small>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTrackModal">
            <i class="fas fa-plus me-1"></i> Add New Track
        </button>
    </div>

    <!-- STATS ROW-->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-primary">@Model.Count</div>
                <div class="text-muted small">Total Tracks</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-success">@Model.Count(t => t.IsActive)</div>
                <div class="text-muted small">Active</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-secondary">@Model.Count(t => !t.IsActive)</div>
                <div class="text-muted small">Inactive</div>
            </div>
        </div>
    </div>

    <!-- TRACKS TABLE-->
    <div class="card shadow-sm border-0">
        <div class="card-header fw-bold bg-primary text-white">
            <i class="fas fa-list me-2"></i> All Tracks
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Track Name</th>
                        <th>Code</th>
                        <th class="text-center">Modules</th>
                        <th class="text-center">Students</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var track in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold">@track.Name</span>
                            </td>
                            <td>
                                <span class="badge bg-dark fs-6 fw-bold font-monospace">@track.Code</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-info text-dark">
                                    @(track.Modules?.Count ?? 0)
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge @(track.Students?.Any() == true ? "bg-primary" : "bg-secondary")">
                                    @(track.Students?.Count ?? 0)
                                </span>
                            </td>
                            <td class="text-center">
                                @if (track.IsActive)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="fas fa-ban me-1"></i>Inactive</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">

                                    <!-- EDIT BUTTON-->
                                    <button class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editTrackModal"
                                            data-id="@track.Id"
                                            data-name="@track.Name"
                                            data-code="@track.Code"
                                            title="Rename track">
                                        <i class="fas fa-pencil-alt"></i>
                                    </button>

                                    <!-- TOGGLE ACTIVE-->
                                    <form asp-action="ToggleTrack" asp-controller="Admin" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@track.Id" />
                                        <button type="submit"
                                                class="btn btn-sm @(track.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(track.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fas @(track.IsActive ? "fa-ban" : "fa-check")"></i>
                                        </button>
                                    </form>

                                    <!-- DELETE (only if no students)-->
                                    @if (track.Students == null || !track.Students.Any())
                                    {
                                        <form asp-action="DeleteTrack" asp-controller="Admin" method="post"
                                              onsubmit="return confirm('Delete track \'@track.Name\'? This will also delete all its modules.')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@track.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete track">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-danger disabled" title="Cannot delete — has enrolled students" disabled>
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fas fa-road fa-2x mb-2 d-block"></i>
                                No tracks found. Add your first track above.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ============ ADD TRACK MODAL ============-->
<div class="modal fade" id="addTrackModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-plus me-2"></i> Add New Track</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateTrack" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Track Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control"
                               placeholder="e.g. Frontend JavaScript" required maxlength="100" />
                        <div class="form-text">The full name of the programme.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Track Code <span class="text-danger">*</span></label>
                        <input type="text" name="code" class="form-control text-uppercase font-monospace"
                               placeholder="e.g. FEJ" required maxlength="6"
                               oninput="this.value = this.value.toUpperCase()" />
                        <div class="form-text">Short unique code (max 6 characters). Used in module codes like <code>FEJ-01</code>.</div>
                    </div>
                    <div class="alert alert-info py-2 small mb-0">
                        <i class="fas fa-info-circle me-1"></i>
                        19 modules (18 learning + 1 mini project) will be auto-created for this track.
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> Create Track
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ============ EDIT TRACK MODAL ============-->
<div class="modal fade" id="editTrackModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold"><i class="fas fa-pencil-alt me-2"></i> Edit Track</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="EditTrack" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editTrackId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Track Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" id="editTrackName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Track Code <span class="text-danger">*</span></label>
                        <input type="text" name="code" id="editTrackCode" class="form-control text-uppercase font-monospace"
                               required maxlength="6" oninput="this.value = this.value.toUpperCase()" />
                        <div class="form-text text-warning">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            Changing the code does not rename existing module codes — only new modules will use the new code.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning text-dark fw-bold">
                        <i class="fas fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Populate edit modal with row data
        document.getElementById('editTrackModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editTrackId').value   = btn.getAttribute('data-id');
            document.getElementById('editTrackName').value = btn.getAttribute('data-name');
            document.getElementById('editTrackCode').value = btn.getAttribute('data-code');
        });
    </script>
}
