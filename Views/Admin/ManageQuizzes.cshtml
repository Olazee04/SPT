@model IEnumerable<SPT.Models.SyllabusModule>
@{
    ViewData["Title"] = "Manage Quizzes";
    bool isAdmin = ViewBag.IsAdmin ?? true;
    int? mentorTrackId = ViewBag.MentorTrackId as int?;
    var availableTracks = ViewBag.Tracks as List<SPT.Models.Track>;
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">
                <i class="fas fa-tasks me-2"></i>Manage Quizzes
            </h2>
            <p class="text-muted mb-0">
                @if (!isAdmin && mentorTrackId != null)
                {
                    <span>Showing modules for your assigned track only.</span>
                }
                else
                {
                    <span>Enable quizzes or manage quiz questions for modules.</span>
                }
            </p>
        </div>
    </div>

    @* ── Track Filter — only for admin or general mentors ── *@
    @if (isAdmin || mentorTrackId == null)
    {
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body bg-light rounded">
                <form method="get" class="row g-3 align-items-center">
                    <div class="col-auto">
                        <label class="fw-bold text-uppercase small text-muted">Filter by Track:</label>
                    </div>
                    <div class="col-auto">
                        <select name="trackId" class="form-select" onchange="this.form.submit()">
                            <option value="">-- Show All Tracks --</option>
                            @if (availableTracks != null)
                            {
                                foreach (var track in availableTracks)
                                {
                                    if (ViewBag.SelectedTrackId != null && (int)ViewBag.SelectedTrackId == track.Id)
                                    {
                                        <option value="@track.Id" selected>@track.Name (@track.Code)</option>
                                    }
                                    else
                                    {
                                        <option value="@track.Id">@track.Name (@track.Code)</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-primary text-white">
                        <tr>
                            <th class="ps-4">Track</th>
                            <th>Code</th>
                            <th>Module Name</th>
                            <th class="text-center">Questions</th>
                            <th>Quiz Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-folder-open fa-3x mb-3 opacity-50 d-block"></i>
                                    <p>No modules found for this selection.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                @* ✅ FIX: Use real question count, not just the HasQuiz flag
                        Questions are included via .Include(m => m.Questions) in controller *@
                                int qCount = item.Questions?.Count ?? 0;
                                bool isReallyEnabled = item.HasQuiz && qCount > 0;

                                <tr>
                                    <td class="ps-4">
                                        <span class="badge bg-secondary">@item.Track?.Code</span>
                                    </td>
                                    <td class="fw-bold">@item.ModuleCode</td>
                                    <td>@item.ModuleName</td>
                                    <td class="text-center">
                                        @if (qCount > 0)
                                        {
                                            <span class="badge bg-primary">@qCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (isReallyEnabled)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle me-1"></i>Enabled
                                            </span>
                                        }
                                        else if (qCount > 0 && !item.HasQuiz)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-pause-circle me-1"></i>Has Questions (Disabled)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border">No Quiz</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Quiz" asp-action="Manage"
                                           asp-route-moduleId="@item.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit me-1"></i>Edit Quiz
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
