@model IEnumerable<SPT.Models.AuditLog>
@{
    ViewData["Title"] = "System Audit Logs";
    string activeTab = ViewBag.ActiveTab as string ?? "All";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">🔒 Security Audit Logs</h2>
        <span class="badge bg-secondary fs-6">@Model.Count() records</span>
    </div>

    @* Tab Navigation *@
    <ul class="nav nav-tabs mb-3 support-tabs" id="auditTabs">
        @foreach (var tab in new[] {
        ("All",      "📋", "All Logs"),
        ("Student",  "🎓", "Student"),
        ("Mentor",   "👨‍🏫", "Mentor"),
        ("Auth",     "🔑", "Login / Auth"),
        ("System",   "⚙️", "System")
        })
        {
            string tabKey = tab.Item1;
            string tabIcon = tab.Item2;
            string tabLabel = tab.Item3;
            bool isActive = activeTab == tabKey;
            <li class="nav-item">
                <a class="nav-link @(isActive ? "active" : "")"
                   href="?tab=@tabKey">
                    @tabIcon @tabLabel
                </a>
            </li>
        }
    </ul>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="width:150px;">Time</th>
                            <th style="width:160px;">Action</th>
                            <th>Details</th>
                            <th style="width:150px;">Performed By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                    No logs found for this category
                                </td>
                            </tr>
                        }
                        @foreach (var log in Model)
                        {
                            string badgeClass = log.Action.Contains("DELETE") ? "bg-danger"
                            : log.Action.Contains("CREATE") ? "bg-success"
                            : log.Action.Contains("LOGIN") ? "bg-primary"
                            : log.Action.Contains("REJECT") ? "bg-warning text-dark"
                            : log.Action.Contains("IMPORT") ? "bg-info"
                            : log.Action.Contains("RESET") ? "bg-danger"
                            : log.Action.Contains("REQUEST") ? "bg-secondary opacity-75"
                            : "bg-secondary";
                            <tr>
                                <td class="ps-3 small text-muted">@log.Timestamp.ToString("MMM dd, HH:mm")</td>
                                <td>
                                    <span class="badge @badgeClass" style="font-size:.72rem;">@log.Action</span>
                                </td>
                                <td class="lb-name small">@log.Details</td>
                                <td class="fw-semibold small lb-name">@log.PerformedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_Pagination")
</div>
