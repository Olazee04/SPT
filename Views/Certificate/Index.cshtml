@model IEnumerable<SPT.Models.Certificate>
@{
    ViewData["Title"] = "Certificates";
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="custom-card p-3 border-start border-4 border-warning h-100">
            <div class="small text-muted text-uppercase fw-bold mb-1">Total Issued</div>
            <div class="h3 fw-bold text-warning mb-0">@Model.Count()</div>
            <div class="small text-muted">certificates on record</div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="fas fa-certificate text-warning me-2"></i> Certificates
    </h4>
    <a asp-action="Eligibility" class="btn btn-success">
        <i class="fas fa-user-graduate me-1"></i> Check Eligibility &amp; Issue
    </a>
</div>

<div class="custom-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Certificate ID</th>
                    <th>Student</th>
                    <th>Track</th>
                    <th>Date Issued</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-secondary fw-normal font-monospace">@item.CertificateId</span>
                        </td>
                        <td class="fw-bold">@item.Student.FullName</td>
                        <td><span class="badge bg-light border fw-bold">@item.TrackName</span></td>
                        <td class="small text-muted">@item.DateIssued.ToString("MMM dd, yyyy")</td>
                        <td class="text-end pe-4">
                            <a asp-action="ViewCertificate" asp-route-id="@item.CertificateId"
                               target="_blank" class="btn btn-sm btn-primary">
                                <i class="fas fa-print me-1"></i> View / Print
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fas fa-certificate fa-3x opacity-25 d-block mb-3"></i>
                            No certificates issued yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>