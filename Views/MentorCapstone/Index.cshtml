@model List<SPT.Models.Capstone>
@{
    ViewData["Title"] = "Capstone Reviews";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="fas fa-project-diagram text-primary"></i> Capstone Reviews
        </h2>
        @if (Model.Any())
        {
            <div class="d-flex gap-2">
                <span class="badge bg-success fs-6">
                    @Model.Count(c => c.Status == SPT.Models.CapstoneStatus.Approved) Approved
                </span>
                <span class="badge bg-warning fs-6">
                    @Model.Count(c => c.Status == SPT.Models.CapstoneStatus.Pending) Pending
                </span>
                <span class="badge bg-danger fs-6">
                    @Model.Count(c => c.Status == SPT.Models.CapstoneStatus.Rejected) Rejected
                </span>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No capstone submissions yet.</div>
        return;
    }

    <div class="card shadow-sm leaderboard-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                @* FIX: table-light → removed *@
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Cohort</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th class="text-end pe-4"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-bold">@c.Student.FullName</td>
                            <td>@c.Student.Cohort?.Name</td>
                            <td>@c.Title</td>
                            <td>
                                <span class="badge
                                    @(c.Status == SPT.Models.CapstoneStatus.Approved ? "bg-success" :
                                      c.Status == SPT.Models.CapstoneStatus.Rejected ? "bg-danger" :
                                      "bg-warning")">
                                    @c.Status
                                </span>
                            </td>
                            <td>@c.SubmittedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Review" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-primary">Review</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* PAGINATION *@
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer d-flex justify-content-between align-items-center">
                <small class="text-muted">Page @ViewBag.CurrentPage of @ViewBag.TotalPages</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)"><i class="fas fa-chevron-left"></i></a>
                        </li>
                        @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                        {
                            <li class="page-item @(p == (int)ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="?page=@p">@p</a>
                            </li>
                        }
                        <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)"><i class="fas fa-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>