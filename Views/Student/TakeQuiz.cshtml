@model List<SPT.Models.QuizQuestion>
@{
    var module = ViewBag.Module as SPT.Models.SyllabusModule;
    ViewData["Title"] = "Quiz: " + module.ModuleName;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 leaderboard-card">
                <div class="card-header bg-primary text-center py-4">
                    <h3 class="mb-0 fw-bold">@module.ModuleName Quiz</h3>
                    <p class="mb-0 opacity-75">Answer all questions to unlock the next module.</p>
                </div>
                <div class="card-body p-4 leaderboard-card">
                    <form asp-action="SubmitQuiz" method="post">
                        <input type="hidden" name="moduleId" value="@module.Id" />

                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var q = Model[i];
                            <div class="mb-4">
                                <h5 class="fw-bold leaderboard-card">@(i + 1). @q.QuestionText</h5>
                                <div class="list-group mt-2">
                                    @foreach (var opt in q.Options)
                                    {
                                        @* FIX: was cursor-pointer, now quiz-option so our CSS targets it *@
                                        <label class="list-group-item list-group-item-action d-flex align-items-center quiz-option">
                                            <input class="form-check-input me-3" type="radio" name="answers[@q.Id]" value="@opt.Id" required>
                                            @opt.OptionText
                                        </label>
                                    }
                                </div>
                            </div>
                            <hr class="text-muted opacity-25" />
                        }

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg" onclick="return confirm('Are you sure you want to submit?');">
                                <i class="fas fa-paper-plane"></i> Submit Answers
                            </button>
                            <a asp-action="Curriculum" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .quiz-option {
        cursor: pointer;
    }
        /* FIX: was hardcoded #f8f9fa */
        .quiz-option:hover {
            background-color: var(--bg-secondary) !important;
        }
        /* FIX: was hardcoded #e8f4fd / #0d6efd */
        .quiz-option:has(input:checked) {
            background-color: rgba(var(--bs-primary-rgb), 0.12) !important;
            border-color: var(--bs-primary) !important;
            color: var(--bs-primary) !important;
            font-weight: bold;
        }
</style>
