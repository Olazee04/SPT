@model List<SPT.Models.QuizAttempt>
@{
    ViewData["Title"] = "My Module Quiz Results";
    int total = Model.Count;
    int passCount = Model.Count(a => a.Passed);
    int failCount = total - passCount;
    double passRate = total > 0 ? Math.Round((double)passCount / total * 100, 1) : 0;
    double avgScore = total > 0 ? Math.Round(Model.Average(a => (double)a.Score), 1) : 0;
}

<div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold">
                <i class="fas fa-graduation-cap text-primary me-2"></i>My Module Quiz Results
            </h2>
            <p class="text-muted mb-0">
                Scores from module exams — you need <strong>75%</strong> to unlock the next module.
            </p>
        </div>
    </div>

    @* ── Quiz Type Explainer ── *@
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="alert alert-primary border-start border-4 border-primary mb-0">
                <strong><i class="fas fa-graduation-cap me-2"></i>Module Quiz (This Page)</strong><br />
                <small>
                    Taken from the Curriculum page. Passing (75%+) unlocks the next module.
                    Each failed attempt requires 2 more hours before you can retry.
                </small>
            </div>
        </div>
        <div class="col-md-6">
            <div class="alert alert-secondary border-start border-4 border-secondary mb-0">
                <strong><i class="fas fa-clipboard-list me-2"></i>Log Exercise Score (in Progress Logs)</strong><br />
                <small>
                    Given by your mentor when grading a class exercise or assignment.
                    Visible in your Progress Log history — not shown here.
                </small>
            </div>
        </div>
    </div>

    @* ── Stat Cards ── *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm border-start border-4 border-primary">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Total Attempts</h6>
                    <h2 class="fw-bold text-primary mb-0">@total</h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm border-start border-4 border-success">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Passed</h6>
                    <h2 class="fw-bold text-success mb-0">@passCount</h2>
                    <small class="text-muted">@passRate% pass rate</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm border-start border-4 border-danger">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Failed</h6>
                    <h2 class="fw-bold text-danger mb-0">@failCount</h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm border-start border-4 border-warning">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Avg Score</h6>
                    <h2 class="fw-bold text-warning mb-0">@avgScore%</h2>
                </div>
            </div>
        </div>
    </div>

    @* ── Attempts Table ── *@
    <div class="card shadow-sm border-0">
        <div class="card-header fw-bold d-flex justify-content-between align-items-center">
            <span><i class="fas fa-list me-2 text-primary"></i>Quiz Attempt History</span>
            <span class="badge bg-secondary">@total record(s)</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Module</th>
                        <th style="width:220px;">Score</th>
                        <th class="text-center">Result</th>
                        <th>Date</th>
                        <th>Outcome</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@(a.Module?.ModuleName ?? "—")</div>
                                    <small class="text-muted">@(a.Module?.ModuleCode ?? "")</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:8px;">
                                            <div class="progress-bar @(a.Passed ? "bg-success" : "bg-danger")"
                                                 style="width:@a.Score%"></div>
                                        </div>
                                        <span class="fw-bold small @(a.Passed ? "text-success" : "text-danger")">
                                            @a.Score%
                                        </span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-@(a.Passed ? "success" : "danger") px-3 py-2">
                                        @(a.Passed ? "✅ Pass" : "❌ Fail")
                                    </span>
                                </td>
                                <td class="text-muted small">
                                    @a.AttemptedAt.ToString("MMM dd, yyyy – HH:mm")
                                </td>
                                <td>
                                    @if (a.Passed)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success">
                                            <i class="fas fa-unlock me-1"></i>Next Module Unlocked
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">
                                            <i class="fas fa-lock me-1"></i>Log 2 more hrs, then retry
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-graduation-cap fa-3x text-muted opacity-25 mb-3 d-block"></i>
                                <h6 class="text-muted">No module quiz attempts yet</h6>
                                <p class="text-muted small">
                                    Complete 8+ hours on a module, then take the quiz from the
                                    <a asp-controller="Student" asp-action="Curriculum">Curriculum</a> page.
                                </p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
